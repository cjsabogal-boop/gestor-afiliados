rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Bloquear TODO el acceso desde navegadores cliente o scripts a nivel cliente.
      // Todas las lecturas y escrituras se hacen desde Server Actions de Next.js
      // mediante firebase-admin (cuyas credenciales saltan estas reglas nativamente).
      allow read, write: if false;
    }
  }
}
