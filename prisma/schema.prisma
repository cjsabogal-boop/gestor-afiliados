// GestorAfiliados - Schema de Base de Datos
// SaaS para administración de edificios/clubes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================
// USUARIO ADMINISTRADOR DEL SAAS
// =====================================
model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String   // Para auth futura
  phone        String?  // Para recibir alertas
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones - Un admin puede manejar múltiples organizaciones
  organizations Organization[]
}

// =====================================
// MULTI-TENANCY: Organización (Edificio/Club)
// =====================================
enum OrganizationType {
  EDIFICIO     // Propiedad Horizontal
  CLUB         // Club social/deportivo
  FONDO        // Fondo de empleados
  OTRO
}

model Organization {
  id        String           @id @default(cuid())
  adminId   String?          // Administrador dueño
  name      String           // "Edificio Torres del Parque"
  type      OrganizationType @default(EDIFICIO)
  address   String?
  phone     String?
  email     String?          // Email de contacto
  logo      String?          // URL del logo
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relaciones
  admin        Admin?        @relation(fields: [adminId], references: [id], onDelete: SetNull)
  affiliates   Affiliate[]
  invoices     Invoice[]
  payments     Payment[]
  alertConfigs AlertConfig[]
  alertLogs    AlertLog[]

  @@index([adminId])
  @@index([isActive])
}

// =====================================
// AFILIADO (Vecino/Miembro)
// =====================================
model Affiliate {
  id             String   @id @default(cuid())
  organizationId String
  name           String   // "Carlos Martínez"
  email          String?  // Para envío de emails
  phone          String   // "+573001234567" - para WhatsApp
  unit           String   // "Apto 301" o "Torre A - 502"
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Preferencias de notificación
  notifyByEmail    Boolean @default(true)
  notifyByWhatsapp Boolean @default(true)

  // Relaciones
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
  payments     Payment[]
  alertLogs    AlertLog[]

  @@index([organizationId])
  @@index([isActive])
}

// =====================================
// FACTURA/CUOTA
// =====================================
enum InvoiceStatus {
  PENDING // Amarillo - Por vencer
  OVERDUE // Rojo - Vencida (mora)
  PAID    // Verde - Pagada
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  affiliateId    String
  concept        String        // "Cuota Administración - Enero 2025"
  amount         Decimal       @db.Decimal(12, 2) // Nunca Float para dinero
  dueDate        DateTime      // Fecha de vencimiento
  status         InvoiceStatus @default(PENDING)
  paidAt         DateTime?     // Fecha de pago (si aplica)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relaciones
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  affiliate    Affiliate    @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  payments     Payment[]
  alertLogs    AlertLog[]

  @@index([organizationId])
  @@index([affiliateId])
  @@index([status])
  @@index([dueDate])
}

// =====================================
// PAGO
// =====================================
enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  PSE
  NEQUI
  DAVIPLATA
  TARJETA
  OTRO
}

model Payment {
  id             String        @id @default(cuid())
  organizationId String
  affiliateId    String
  invoiceId      String?
  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod @default(TRANSFERENCIA)
  reference      String?       // Número de referencia del pago
  notes          String?
  createdAt      DateTime      @default(now())

  // Relaciones
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  affiliate    Affiliate    @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([affiliateId])
  @@index([createdAt])
}

// =====================================
// CONFIGURACIÓN DE ALERTAS
// =====================================
enum AlertChannel {
  WHATSAPP
  EMAIL
  BOTH
}

enum AlertTrigger {
  DAYS_BEFORE_DUE  // X días antes del vencimiento
  ON_DUE_DATE      // El día del vencimiento
  DAYS_AFTER_DUE   // X días después del vencimiento (mora)
}

model AlertConfig {
  id             String       @id @default(cuid())
  organizationId String
  name           String       // "Recordatorio 5 días antes"
  trigger        AlertTrigger
  daysOffset     Int          // Número de días (antes o después según trigger)
  channel        AlertChannel @default(BOTH)
  isActive       Boolean      @default(true)
  
  // Plantilla del mensaje
  messageTemplate String      // Texto con variables: {nombre}, {unidad}, {monto}, {fecha}
  
  // Horario de envío
  sendHour       Int          @default(9) // Hora del día (0-23) para enviar
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relaciones
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  alertLogs    AlertLog[]

  @@index([organizationId])
  @@index([isActive])
}

// =====================================
// HISTORIAL DE ALERTAS ENVIADAS
// =====================================
enum AlertStatus {
  PENDING   // Programada
  SENT      // Enviada exitosamente
  FAILED    // Error en el envío
  SKIPPED   // Omitida (afiliado optó por no recibir)
}

model AlertLog {
  id             String      @id @default(cuid())
  organizationId String
  affiliateId    String
  invoiceId      String?
  alertConfigId  String?
  
  channel        AlertChannel
  status         AlertStatus  @default(PENDING)
  message        String       // Mensaje enviado
  errorMessage   String?      // Mensaje de error si falló
  
  scheduledFor   DateTime     // Cuándo se debe enviar
  sentAt         DateTime?    // Cuándo se envió realmente
  createdAt      DateTime     @default(now())

  // Relaciones
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  affiliate    Affiliate     @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  alertConfig  AlertConfig?  @relation(fields: [alertConfigId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([affiliateId])
  @@index([status])
  @@index([scheduledFor])
}
